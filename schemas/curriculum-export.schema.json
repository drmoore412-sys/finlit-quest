{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://finlit.quest/schemas/curriculum-export.schema.json",
  "title":"FinLit Quest generated curriculum export",
  "type":"object",
  "additionalProperties":false,
  "required":["schemaVersion","curriculumVersion","world","generatedAt","source","sections","objectives"],
  "properties":{
    "schemaVersion":{"const":1},
    "curriculumVersion":{"type":"string","minLength":1},
    "world":{"type":"string","minLength":1},
    "generatedAt":{"type":"string","format":"date-time"},
    "source":{
      "type":"object",
      "additionalProperties":false,
      "required":["workbooks","approvalLogHash","controlledValuesHash"],
      "properties":{
        "workbooks":{"type":"array","minItems":1,"items":{"type":"object","additionalProperties":false,"required":["fileName","sha256"],"properties":{"fileName":{"type":"string","minLength":1},"sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"}}}},
        "approvalLogHash":{"type":"string","pattern":"^[a-f0-9]{64}$"},
        "controlledValuesHash":{"type":"string","pattern":"^[a-f0-9]{64}$"}
      }
    },
    "sections":{"type":"array","minItems":1,"items":{"$ref":"section.schema.json"}},
    "objectives":{"type":"array","minItems":1,"items":{"$ref":"objective.schema.json"}}
  }
}
