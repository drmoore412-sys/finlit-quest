{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://finlit.quest/schemas/workbook-world.schema.json",
  "title": "FinLit Quest workbook-style world manifest (lesson/quiz worlds, distinct from word-connect worlds)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "worldType", "name", "eyebrow", "sequential", "workbookIds"],
  "properties": {
    "schemaVersion": {"type": "integer", "minimum": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
    "worldType": {"const": "workbook"},
    "name": {"type": "string", "minLength": 1},
    "eyebrow": {"type": "string", "minLength": 1},
    "sequential": {"type": "boolean"},
    "workbookIds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z]{2,6}-[0-9]{3}$"}}
  }
}
