{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://finlit.quest/schemas/objective.schema.json",
  "title":"FinLit Quest approved learning objective",
  "type":"object",
  "additionalProperties":false,
  "required":["id","world","sectionId","title","statement","difficulty","approvalStatus","curriculumVersion","termIds","prerequisiteObjectiveIds","metadata"],
  "properties":{
    "id":{"type":"string","pattern":"^[a-z0-9_-]+\\.objective\\.[a-z0-9_-]+$"},
    "world":{"type":"string","minLength":1},
    "sectionId":{"type":"string","minLength":1},
    "title":{"type":"string","minLength":1},
    "statement":{"type":"string","minLength":1},
    "difficulty":{"enum":["beginner","intermediate","advanced","expert","master"]},
    "approvalStatus":{"const":"approved_locked"},
    "curriculumVersion":{"type":"string","minLength":1},
    "termIds":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string"}},
    "prerequisiteObjectiveIds":{"type":"array","uniqueItems":true,"items":{"type":"string"}},
    "scenarioIds":{"type":"array","uniqueItems":true,"items":{"type":"string"}},
    "challengeIds":{"type":"array","uniqueItems":true,"items":{"type":"string"}},
    "metadata":{"type":"object","additionalProperties":true,"required":["order"],"properties":{"order":{"type":"integer","minimum":0},"estimatedMinutes":{"type":"number","minimum":0},"tags":{"type":"array","uniqueItems":true,"items":{"type":"string"}}}}
  }
}
